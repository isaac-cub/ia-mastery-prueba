---
import home from '../content/home.json';
const h = home;
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{h.seoTitle}</title>
<meta name="description" content={h.seoDescription} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700;800&family=Caveat:wght@600;700&display=swap" rel="stylesheet" />
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        ink:   '#0B1220',
        paper: '#F5F8FF',
        brand: { DEFAULT: '#0052CC', deep: '#003A99', bright: '#2D7FF9', soft: '#E8F0FF' },
        gold:  { DEFAULT: '#FFC83D', deep: '#E0A100' },
      },
      fontFamily: {
        display: ['"Bricolage Grotesque"', 'sans-serif'],
        sans: ['Inter', 'sans-serif'],
        hand: ['Caveat', 'cursive'],
      },
      maxWidth: { read: '40rem' },
    },
  },
};
</script>
<style is:global>
  html { -webkit-text-size-adjust: 100%; }
  body { background: #F5F8FF; color: #0B1220; font-size: 17px; line-height: 1.6; text-rendering: optimizeLegibility; }
  ::selection { background: #0052CC; color: #fff; }

  .mesh {
    background:
      radial-gradient(55% 50% at 12% 8%, rgba(0,82,204,.16), transparent 60%),
      radial-gradient(50% 45% at 88% 4%, rgba(45,127,249,.16), transparent 60%),
      radial-gradient(45% 45% at 72% 88%, rgba(255,200,61,.14), transparent 60%);
  }
  .grain:before { content:""; position:absolute; inset:0; opacity:.5; pointer-events:none;
    background-image: radial-gradient(rgba(255,255,255,.06) 1px, transparent 1px); background-size: 4px 4px; }

  .lede p { font-size: clamp(1.12rem, 1rem + .5vw, 1.45rem); line-height: 1.62; }
  .lede p + p { margin-top: 1.25rem; }

  .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s cubic-bezier(.2,.7,.2,1), transform .7s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }

  .card-glow { box-shadow: 0 1px 2px rgba(11,18,32,.04), 0 18px 40px -18px rgba(0,82,204,.28); }
  .cta-glow  { box-shadow: 0 12px 30px -8px rgba(0,82,204,.55); }

  .scribble { position: relative; display: inline-block; }
  .scribble svg { position: absolute; left: -2%; bottom: -.42em; width: 104%; height: .5em; overflow: visible; }

  .marquee { display: flex; gap: 0; overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); }
  .marquee__track { display: flex; flex-shrink: 0; align-items: center; gap: 2.5rem; padding-right: 2.5rem; animation: scroll 34s linear infinite; }
  @keyframes scroll { to { transform: translateX(-100%); } }
  .marquee:hover .marquee__track { animation-play-state: paused; }

  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .faq-ic { transform: rotate(45deg); }

  .vid { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (prefers-reduced-motion: reduce){ .reveal{opacity:1;transform:none} .marquee__track{animation:none} }
</style>
</head>
<body class="font-sans antialiased pb-24 md:pb-0">

<!-- SCROLL PROGRESS -->
<div class="fixed top-0 inset-x-0 z-[60] h-1 bg-transparent pointer-events-none">
  <div id="progress" class="h-full w-0 bg-gradient-to-r from-brand via-brand-bright to-gold transition-[width] duration-100 ease-out"></div>
</div>

<!-- 0 · ANNOUNCEMENT -->
<div class="bg-ink text-white text-center text-[13px] sm:text-sm py-2.5 px-4 font-medium tracking-tight">
  <span class="text-gold">✦</span> {h.announcement}
</div>

<!-- HEADER -->
<header id="hdr" class="sticky top-0 z-50 transition-all duration-300 bg-paper/80 backdrop-blur-md border-b border-transparent">
  <nav class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
    <a href="#" class="font-display font-extrabold text-xl tracking-tight">AI<span class="text-brand">Mastery</span></a>
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-ink/65">
      {h.nav.map((n) => <a href={n.href} class="hover:text-ink transition">{n.label}</a>)}
    </div>
    <a href={h.headerCta.href} class="bg-ink text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-brand transition-colors">{h.headerCta.label}</a>
  </nav>
</header>

<!-- 1 · HERO -->
<section class="relative overflow-hidden mesh">
  <div class="max-w-6xl mx-auto px-5 pt-14 pb-16 md:pt-20 md:pb-24 grid md:grid-cols-[1.05fr_.95fr] gap-12 items-center">
    <div class="reveal">
      <div class="inline-flex items-center gap-2 bg-white/80 border border-brand/15 rounded-full pl-1.5 pr-3.5 py-1.5 text-xs font-semibold text-brand mb-7 shadow-sm">
        <span class="bg-brand text-white rounded-full px-2 py-0.5">NUEVO</span> {h.hero.badge}
      </div>
      <h1 class="font-display font-extrabold tracking-tight leading-[0.96] text-[clamp(2.5rem,6vw,4.3rem)]">
        {h.hero.h1Line1}<br>
        <span class="scribble text-brand">{h.hero.h1Highlight}
          <svg viewBox="0 0 320 16" fill="none" preserveAspectRatio="none"><path d="M4 11C70 4 232 3 316 8" stroke="#FFC83D" stroke-width="6" stroke-linecap="round"/></svg>
        </span><br>
        {h.hero.h1Line3}
      </h1>
      <p class="mt-7 text-lg sm:text-xl text-ink/70 max-w-md leading-relaxed" set:html={h.hero.lead}></p>
      <div class="mt-8 flex flex-wrap items-center gap-3.5">
        <a href={h.hero.ctaPrimary.href} class="cta-glow bg-gold text-ink font-semibold px-7 py-4 rounded-full hover:bg-white transition-colors">{h.hero.ctaPrimary.label}</a>
        <a href={h.hero.ctaSecondary.href} class="font-semibold px-6 py-4 rounded-full border border-ink/15 hover:border-ink/40 transition">{h.hero.ctaSecondary.label}</a>
      </div>
      <div class="mt-8 flex items-center gap-4 text-sm">
        <div class="flex -space-x-2.5">
          {h.hero.avatars.map((src) => <img src={src} class="w-9 h-9 rounded-full border-2 border-paper object-cover" alt="" />)}
          <span class="w-9 h-9 rounded-full border-2 border-paper bg-brand text-white text-[10px] font-bold grid place-items-center">+1.5K</span>
        </div>
        <div><span class="font-bold">{h.hero.socialProofCount}</span> <span class="text-ink/40">·</span> <span class="text-ink/60">{h.hero.socialProofText}</span></div>
      </div>
    </div>

    <div class="relative reveal">
      <div class="relative w-full">
        <div class="relative rounded-[1.5rem] overflow-hidden card-glow ring-1 ring-ink/5 bg-ink aspect-video">
          <iframe src={h.hero.videoEmbed} loading="lazy" class="absolute inset-0 w-full h-full" allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;" allowfullscreen></iframe>
        </div>
        <div class="absolute -left-3 sm:-left-6 -bottom-4 bg-white rounded-2xl card-glow px-4 py-3 -rotate-3">
          <div class="text-2xl font-display font-extrabold text-brand">{h.hero.chipPrice}<span class="text-sm text-ink/45 font-sans">{h.hero.chipPriceUnit}</span></div>
          <div class="text-[11px] text-ink/55 font-medium">{h.hero.chipNote}</div>
        </div>
        <div class="absolute left-3 top-3 bg-white/90 backdrop-blur text-ink ring-1 ring-ink/10 rounded-full px-3.5 py-1.5 text-xs font-semibold flex items-center gap-1.5 shadow-lg">
          <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span> Generado con IA
        </div>
        <p class="font-hand text-brand text-[1.6rem] leading-none absolute -bottom-7 right-2 -rotate-6 hidden md:block">{h.hero.handNote}</p>
      </div>
    </div>
  </div>
</section>

<!-- 2 · MARQUEE -->
<div class="bg-ink text-white py-4 border-y border-white/5 overflow-hidden">
  <div class="marquee">
    {[0, 1].map(() => (
      <div class="marquee__track font-display font-bold text-lg sm:text-xl tracking-tight" aria-hidden="true">
        {h.marquee.tools.map((tool, i) => (
          <>
            <span class="line-through decoration-2 decoration-white/50 text-white/70">{tool}</span>
            <span class="text-gold">· {h.marquee.phrases[i % h.marquee.phrases.length]} ·</span>
          </>
        ))}
      </div>
    ))}
  </div>
</div>
<div class="bg-white border-b border-ink/10">
  <div class="max-w-6xl mx-auto px-5 py-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm font-medium text-ink/65">
    <span class="text-ink/55 text-xs uppercase tracking-widest">{h.marquee.forLabel}</span>
    {h.marquee.platforms.map((p) => <span>{p}</span>)}
  </div>
</div>

<!-- 3 · ENTRADA 01 -->
<section class="max-w-read mx-auto px-5 py-14 md:py-28">
  <div class="reveal">
    <span class="text-xs font-bold tracking-[0.2em] text-brand uppercase">{h.entry01.eyebrow}</span>
    <h2 class="font-display font-extrabold text-[clamp(2rem,4.6vw,3rem)] leading-[1.04] mt-4" set:html={h.entry01.heading}></h2>
    <div class="lede mt-8 text-ink/75">
      <p>{h.entry01.para1}</p>
      <p class="!mt-6 text-ink/90 font-medium leading-snug" set:html={h.entry01.listTools}></p>
      <p set:html={h.entry01.para2}></p>
    </div>
    <div class="mt-8 grid sm:grid-cols-2 gap-3">
      {h.entry01.cons.map((c) => (
        <div class="flex items-start gap-3 bg-white rounded-2xl p-4 border border-ink/8">
          <span class="text-red-500 font-bold text-lg leading-none mt-0.5">✖</span>
          <p class="text-[15px] text-ink/75" set:html={c}></p>
        </div>
      ))}
    </div>
    <div class="lede mt-8 text-ink/75">
      <p>{h.entry01.para3}</p>
      <p class="!mt-7 font-display font-bold text-ink text-[clamp(1.3rem,2.6vw,1.7rem)] leading-snug">{h.entry01.question}</p>
    </div>
    <p class="font-hand text-brand text-[1.9rem] leading-none mt-5 flex items-center gap-3">
      {h.entry01.handNote}
      <svg width="46" height="26" viewBox="0 0 46 26" fill="none" class="-rotate-3 shrink-0 hidden sm:block"><path d="M2 5C14 19 30 22 42 14" stroke="#0052CC" stroke-width="2.5" stroke-linecap="round"/><path d="M42 14L34 16M42 14L38 7" stroke="#0052CC" stroke-width="2.5" stroke-linecap="round"/></svg>
    </p>
  </div>
</section>

<!-- 4 · ENTRADA 02 -->
<section class="bg-white border-y border-ink/10">
  <div class="max-w-read mx-auto px-5 py-14 md:py-28">
    <div class="reveal">
      <span class="text-xs font-bold tracking-[0.2em] text-brand uppercase">{h.entry02.eyebrow}</span>
      <h2 class="font-display font-extrabold text-[clamp(2rem,4.6vw,3rem)] leading-[1.04] mt-4">{h.entry02.heading}</h2>
      <div class="lede mt-8 text-ink/75">
        <p set:html={h.entry02.para1}></p>
        <p set:html={h.entry02.para2}></p>
        <p set:html={h.entry02.para3}></p>
      </div>
      <div class="mt-8 grid sm:grid-cols-2 gap-4">
        <div class="rounded-2xl border border-ink/10 p-5 bg-paper">
          <div class="text-xs font-bold uppercase tracking-wider text-ink/40 mb-2">{h.entry02.cardALabel}</div>
          <p class="text-ink/70 text-[15px]">{h.entry02.cardAText}</p>
        </div>
        <div class="rounded-2xl border-2 border-brand/30 p-5 bg-brand-soft">
          <div class="text-xs font-bold uppercase tracking-wider text-brand mb-2">{h.entry02.cardBLabel}</div>
          <p class="text-ink/80 text-[15px]" set:html={h.entry02.cardBText}></p>
        </div>
      </div>
      <p class="lede mt-8 text-ink/75" set:html={h.entry02.para4}></p>
      <p class="font-hand text-brand text-[1.9rem] leading-none mt-6 flex items-center gap-3">
        {h.entry02.handNote}
        <svg width="30" height="40" viewBox="0 0 30 40" fill="none" class="animate-bounce"><path d="M15 3V31" stroke="#FFC83D" stroke-width="3" stroke-linecap="round"/><path d="M5 22L15 33L25 22" stroke="#FFC83D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </p>
    </div>
  </div>
</section>

<!-- 5 · ENTRADA 03 -->
<section class="bg-ink text-white grain relative overflow-hidden">
  <div class="mesh absolute inset-0 opacity-30"></div>
  <div class="max-w-6xl mx-auto px-5 py-14 md:py-28 relative">
    <div class="reveal max-w-xl">
      <span class="text-xs font-bold tracking-[0.2em] text-gold uppercase">{h.entry03.eyebrow}</span>
      <h2 class="font-display font-extrabold text-[clamp(2rem,4.5vw,3.2rem)] leading-[1.04] mt-4">{h.entry03.heading}</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6 mt-12">
      <div class="reveal rounded-3xl border border-white/10 bg-white/[.03] p-8">
        <div class="text-sm font-semibold text-white/45 uppercase tracking-wider">{h.entry03.beforeLabel}</div>
        <div class="font-display font-extrabold text-[clamp(2.6rem,7vw,4rem)] leading-none mt-3 text-white/90">{h.entry03.beforeValue} <span class="text-2xl text-white/40">{h.entry03.beforeUnit}</span></div>
        <p class="mt-4 text-white/60 leading-relaxed">{h.entry03.beforeText}</p>
      </div>
      <div class="reveal rounded-3xl border-2 border-gold/40 bg-gradient-to-br from-brand/20 to-transparent p-8 relative overflow-hidden">
        <span class="absolute top-5 right-5 text-gold text-xs font-bold border border-gold/40 rounded-full px-3 py-1">{h.entry03.afterBadge}</span>
        <div class="text-sm font-semibold text-gold uppercase tracking-wider">{h.entry03.afterLabel}</div>
        <div class="font-display font-extrabold text-[clamp(2.6rem,7vw,4rem)] leading-none mt-3"><span class="count text-gold" data-target={h.entry03.afterValue}>0</span> <span class="text-2xl text-white/40">{h.entry03.afterUnit}</span></div>
        <p class="mt-4 text-white/70 leading-relaxed" set:html={h.entry03.afterText}></p>
      </div>
    </div>
    <p class="reveal mt-12 text-center text-lg sm:text-xl text-white/75 max-w-3xl mx-auto leading-loose" set:html={h.entry03.closer}></p>
  </div>
</section>

<!-- 6 · PROGRAMA -->
<section id="programa" class="max-w-6xl mx-auto px-5 py-14 md:py-28">
  <div class="max-w-2xl reveal">
    <span class="text-xs font-bold tracking-[0.2em] text-brand uppercase">{h.programa.eyebrow}</span>
    <h2 class="font-display font-extrabold text-[clamp(2rem,4.6vw,3.2rem)] leading-[1.04] mt-4" set:html={h.programa.heading}></h2>
    <p class="mt-5 text-lg text-ink/65 leading-relaxed">{h.programa.lead}</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-14">
    {h.programa.cards.map((card) => (
      <article class="reveal group bg-white rounded-3xl overflow-hidden card-glow hover:-translate-y-1 transition-transform duration-300 relative">
        {card.cornerTag && <span class="absolute top-3 right-3 z-10 bg-gold text-ink text-[10px] font-bold px-2.5 py-1 rounded-full rotate-3 shadow">{card.cornerTag}</span>}
        <div class="relative aspect-[4/3] bg-ink overflow-hidden">
          {card.type === 'image'
            ? <img src={card.media} alt="" class="vid" />
            : <video class="vid" src={card.media} autoplay muted loop playsinline preload="metadata"></video>}
          {card.badge && <span class="absolute bottom-3 left-3 text-white text-[11px] font-semibold bg-black/45 rounded-full px-2.5 py-1 backdrop-blur">{card.badge}</span>}
        </div>
        <div class="p-5">
          <h3 class="font-display font-bold text-lg">{card.title}</h3>
          <p class="mt-1.5 text-ink/60 text-sm leading-relaxed">{card.text}</p>
        </div>
      </article>
    ))}
  </div>

  <article class="reveal mt-5 grid md:grid-cols-[1.2fr_1fr] gap-0 bg-ink text-white rounded-3xl overflow-hidden card-glow">
    <div class="p-8 md:p-10 flex flex-col justify-center">
      <span class="inline-flex w-max items-center gap-1.5 bg-gold text-ink text-[11px] font-bold px-2.5 py-1 rounded-full mb-4">{h.programa.highlight.badge}</span>
      <h3 class="font-display font-extrabold text-2xl md:text-3xl leading-tight">{h.programa.highlight.title}</h3>
      <p class="mt-3 text-white/70 leading-relaxed max-w-md">{h.programa.highlight.text}</p>
    </div>
    <div class="relative min-h-[220px] bg-black">
      <video class="vid" src={h.programa.highlight.media} autoplay muted loop playsinline preload="metadata"></video>
    </div>
  </article>
</section>

<!-- 7 · NUEVA CLASE 1 -->
<section class="bg-white border-y border-ink/10">
  <div class="max-w-6xl mx-auto px-5 py-14 md:py-28 grid md:grid-cols-2 gap-12 items-center">
    <div class="relative order-2 md:order-1 reveal">
      <div class="rounded-3xl overflow-hidden aspect-[4/3] bg-ink card-glow ring-1 ring-ink/5">
        <video class="vid" src={h.class01.media} autoplay muted loop playsinline preload="metadata"></video>
      </div>
      <span class="absolute -top-3 -left-3 bg-gold text-ink font-display font-bold text-sm px-3 py-1.5 rounded-full -rotate-6 shadow">{h.class01.badge}</span>
    </div>
    <div class="order-1 md:order-2 reveal">
      <span class="text-xs font-bold tracking-[0.2em] text-brand uppercase">{h.class01.eyebrow}</span>
      <h2 class="font-display font-extrabold text-[clamp(1.9rem,4vw,2.8rem)] leading-[1.05] mt-3">{h.class01.heading}</h2>
      <p class="mt-3 text-lg text-ink/70">{h.class01.lead}</p>
      <p class="mt-4 text-ink/65 leading-relaxed">{h.class01.body}</p>
      <ul class="mt-6 space-y-2.5 text-[15px]">
        {h.class01.bullets.map((b) => <li class="flex gap-2.5"><span class="text-brand font-bold">→</span> {b}</li>)}
      </ul>
    </div>
  </div>
</section>

<!-- 8 · NUEVA CLASE 2 -->
<section class="max-w-6xl mx-auto px-5 py-14 md:py-28 grid md:grid-cols-2 gap-12 items-center">
  <div class="reveal">
    <span class="text-xs font-bold tracking-[0.2em] text-brand uppercase">{h.class02.eyebrow}</span>
    <h2 class="font-display font-extrabold text-[clamp(1.9rem,4vw,2.8rem)] leading-[1.05] mt-3">{h.class02.heading}</h2>
    <p class="mt-3 text-lg text-ink/70">{h.class02.lead}</p>
    <p class="mt-4 text-ink/65 leading-relaxed">{h.class02.body}</p>
    <ul class="mt-6 space-y-2.5 text-[15px]">
      {h.class02.bullets.map((b) => <li class="flex gap-2.5"><span class="text-brand font-bold">→</span> {b}</li>)}
    </ul>
  </div>
  <div class="relative reveal">
    <div class="rounded-3xl overflow-hidden aspect-[4/3] bg-ink card-glow ring-1 ring-ink/5">
      <video class="vid" src={h.class02.media} autoplay muted loop playsinline preload="metadata"></video>
    </div>
    <span class="absolute -top-3 -right-3 bg-gold text-ink font-display font-bold text-sm px-3 py-1.5 rounded-full rotate-6 shadow">{h.class02.badge}</span>
  </div>
</section>

<!-- 9 · MÉTRICAS -->
<section class="bg-brand text-white relative overflow-hidden grain">
  <div class="max-w-6xl mx-auto px-5 py-14 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x divide-white/15">
    {h.metrics.map((m) => (
      <div class="reveal lg:px-8"><div class="font-display font-extrabold text-2xl sm:text-3xl md:text-4xl text-gold">{m.value}</div><p class="mt-2 text-white/80 text-sm leading-snug">{m.text}</p></div>
    ))}
  </div>
</section>

<!-- 10 · LO QUE TE LLEVAS -->
<section class="max-w-5xl mx-auto px-5 py-14 md:py-28">
  <div class="text-center max-w-2xl mx-auto reveal">
    <h2 class="font-display font-extrabold text-[clamp(2rem,4.6vw,3rem)] leading-[1.05]">{h.included.heading}<span class="scribble text-brand">{h.included.headingHighlight}<svg viewBox="0 0 300 16" fill="none" preserveAspectRatio="none"><path d="M4 10C66 4 220 4 296 9" stroke="#FFC83D" stroke-width="6" stroke-linecap="round"/></svg></span></h2>
    <p class="mt-5 text-lg text-ink/65">{h.included.lead}</p>
  </div>
  <div class="grid sm:grid-cols-2 gap-3 mt-12 reveal">
    {h.included.items.map((item) => (
      <div class="flex gap-3 bg-white rounded-2xl p-4 border border-ink/8"><span class="text-brand font-bold">✓</span><p class="text-[15px] text-ink/80" set:html={item}></p></div>
    ))}
    <div class="flex gap-3 bg-brand-soft rounded-2xl p-4 border border-brand/20"><span class="text-brand font-bold">✓</span><p class="text-[15px] text-ink/90 font-medium">{h.included.highlightItem}</p></div>
  </div>
  <div class="text-center mt-10 reveal">
    <a href={h.included.cta.href} class="cta-glow inline-block bg-gold text-ink font-semibold px-8 py-4 rounded-full hover:bg-white transition">{h.included.cta.label}</a>
    <p class="mt-3 text-sm text-ink/50">{h.included.ctaNote}</p>
  </div>
</section>

<!-- 11 · FILOSOFÍA -->
<section class="bg-white border-y border-ink/10">
  <div class="max-w-read mx-auto px-5 py-14 md:py-28 text-center reveal">
    <h2 class="font-display font-extrabold text-[clamp(2.2rem,5.5vw,3.6rem)] leading-[1]">{h.philosophy.headingA}<br><span class="text-brand">{h.philosophy.headingB}</span></h2>
